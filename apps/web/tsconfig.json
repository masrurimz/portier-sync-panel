{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@portier-sync/ui/*": ["../../packages/ui/src/*"],
      "@portier-sync/api": ["../../packages/api/src/index.ts"],
      "@portier-sync/api/msw": ["../../packages/api/src/msw/index.ts"],
      "@portier-sync/api/msw/browser": ["../../packages/api/src/msw/browser.ts"]
    }
  }
}
