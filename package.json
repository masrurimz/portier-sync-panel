{
  "name": "portier-sync",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.87.0",
"@better-fetch/fetch": "^1.1.16",
      "@tanstack/react-query": "^5.80.6",
      "msw": "^2.12.13"
    }
  },
  "type": "module",
  "scripts": {
    "dev:cf": "turbo dev --filter=@portier-sync/infra",
    "dev": "turbo dev --filter=web",
    "build": "turbo build",
    "check:types": "turbo check:types",
    "check:lint": "turbo check:lint",
    "dev:web": "turbo -F web dev",
    "deploy": "turbo -F @portier-sync/infra deploy",
    "destroy": "turbo -F @portier-sync/infra destroy",
    "check": "npm run check:lint && oxfmt --write"
  },
  "dependencies": {
    "@portier-sync/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@portier-sync/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  }
}
